<idea-plugin>
    <id>com.github.jdami.ai-generator-commit-message</id>
    <name>AI Commit Message Generator</name>
    <vendor email="your.email@example.com" url="https://github.com/jdami">jdami</vendor>

    <resource-bundle>messages.AiCommitMessages</resource-bundle>

    <description><![CDATA[
    <h1>AI Commit Message Generator</h1>
    <p>Automatically generate commit messages using AI based on your code changes.</p>
    <p><strong>Works with any VCS:</strong> Git, SVN, Mercurial, Perforce, and more!</p>
    
    <h2>Features</h2>
    <ul>
        <li>Add a button in the commit dialog to generate commit messages</li>
        <li>Analyze staged changes and generate meaningful commit messages</li>
        <li>Customizable AI provider: Ollama, OpenAI, or OpenRouter</li>
        <li>VCS-agnostic: works with Git, SVN, Mercurial, and any VCS supported by IntelliJ</li>
        <li>Cross-platform: Windows, macOS, Linux</li>
    </ul>
    
    <h2>Usage</h2>
    <ol>
        <li>Configure AI provider in Settings → Tools → AI Commit Message Generator</li>
        <li>Open the commit dialog (Ctrl+K / Cmd+K)</li>
        <li>Click the "Commit助手" button</li>
        <li>Review and edit the generated message</li>
    </ol>
    ]]></description>

    <change-notes><![CDATA[
    <h2>1.0.0</h2>
    <ul>
        <li>Initial release</li>
        <li>Generate commit messages using Ollama AI</li>
        <li>Configurable Ollama endpoint</li>
    </ul>
    ]]></change-notes>

    <!-- Product and plugin compatibility requirements -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.vcs</depends>
    <!-- Removed Git4Idea dependency - plugin now works with any VCS (Git, SVN, Mercurial, etc.) -->

    <extensions defaultExtensionNs="com.intellij">
        <!-- Settings -->
        <applicationConfigurable 
            parentId="tools" 
            instance="com.github.jdami.aicommit.settings.AiSettingsConfigurable"
            id="com.github.jdami.aicommit.settings.AiSettingsConfigurable"
            displayName="AI Commit Message Generator"/>
        
        <applicationService 
            serviceImplementation="com.github.jdami.aicommit.settings.AiSettingsState"/>
        
        <!-- VCS Check-in Handler Factory -->
        <checkinHandlerFactory 
            implementation="com.github.jdami.aicommit.vcs.CommitMessageGeneratorCheckinHandlerFactory"/>
            
        <!-- Startup Activity -->
        <postStartupActivity implementation="com.github.jdami.aicommit.startup.PluginUpdateActivity"/>
    </extensions>

    <actions>
        <!-- This action will be added to the commit dialog toolbar -->
        <action 
            id="com.github.jdami.aicommit.GenerateCommitMessageAction"
            class="com.github.jdami.aicommit.actions.GenerateCommitMessageAction"
            text="action.generate.commit.message.text"
            description="action.generate.commit.message.description"
            icon="/icons/aiCommit.svg">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="first"/>
        </action>
    </actions>
</idea-plugin>
